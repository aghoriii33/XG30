# JARVIS AI Assistant - Environment Configurations
# Copy this file to '.env' and fill in your keys.

# OpenAI API Configuration
# Replace with your actual OpenAI API key to enable live GPT-4/GPT-5 responses.
# If left empty or set to "mock", the backend will run in simulation mode.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Stripe API Configuration
# Replace with your Stripe Secret Key (sk_test_...) for payment checkouts.
STRIPE_API_KEY=mock
STRIPE_WEBHOOK_SECRET=mock

# Firebase Admin configuration
# Absolute path to your Firebase Service Account JSON file.
# E.g., C:\Users\yourname\secrets\firebase-key.json
FIREBASE_CREDENTIALS_PATH=
